# Template for the .env file. Copy to .env and fill in real values.
#   cp .env.example .env
# The .env file is gitignored so secrets stay out of source control.

# Bot token issued by @BotFather, e.g. 123456789:AAF...
TELEGRAM_BOT_TOKEN=

# Your bot's @handle, without the leading @, e.g. my_assistant_bot
TELEGRAM_BOT_USERNAME=
